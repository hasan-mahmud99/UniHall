PORT=5000
NODE_ENV=development
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=unihall
JWT_SECRET=change_me

# Firebase Admin (download service account JSON from Firebase Console)
# Option A: put full JSON (one-line string)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: path to the json file
FIREBASE_SERVICE_ACCOUNT_PATH=

# SMTP (required for email OTP password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=UniHall <no-reply@unihall.local>

# Frontend base URL (used to build password reset links for non-Firebase accounts)
# Example (vite dev): http://localhost:5173/UniHall
FRONTEND_BASE_URL=

# Local testing only: if true and SMTP is not configured, OTP will be logged to backend console
EMAIL_DEBUG_LOG_OTP=false

# Password reset OTP settings (optional)
PASSWORD_RESET_OTP_TTL_MINUTES=10
PASSWORD_RESET_OTP_RATE_LIMIT_SECONDS=60
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
